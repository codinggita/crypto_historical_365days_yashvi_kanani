# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration (REQUIRED for deployment)
# For Vercel deployment, set MONGODB_URI in Vercel Environment Variables
MONGODB_URI=your_mongodb_connection_string
# Alternative: MONGO_URI=your_mongodb_connection_string

# JWT Configuration
JWT_SECRET=your_super_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d

# CORS Configuration (comma-separated list of allowed origins)
# For Vercel deployment, add your frontend URL here
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-frontend-url.vercel.app
